# SafeRoute AI – Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit the real .env file!

# ==========================================
# Server / Backend
# ==========================================
PORT=5000
NODE_ENV=development

# MongoDB Atlas or local connection string
MONGODB_URI=mongodb://localhost:27017

# JWT Authentication
JWT_SECRET=api_key
JWT_EXPIRE=30d

# ==========================================
# Maps & External APIs (replacing Google Maps)
# OpenRouteService (server-side routing) - required if you want server routing
ORS_API_KEY=api_key
# OpenWeatherMap (weather / heat index)
OPENWEATHER_API_KEY=api_key
# Optional: Geoapify for server-side geocoding (client uses REACT_APP_GEOAPIFY_API_KEY)
GEOAPIFY_API_KEY=api_key

# ==========================================
# EmailJS (fallback email notifications)
# Register at https://www.emailjs.com and create a service + template.
# The REST API requires `service_id`, `template_id`, and `user_id` (aka public key).
EMAILJS_USER_ID=user_id
EMAILJS_SERVICE_ID=service_id
EMAILJS_TEMPLATE_ID=template_id
+ALERT_EMAIL_TO=google@gmail.com
# Optional override email address for alerts (overrides template `to_email`)
EMAILJS_TO_EMAIL=google@gmail.com

# ==========================================
# AI Microservices (Python/Flask)
# ==========================================
AI_ROUTE_SCORER_URL=http://localhost:5001
AI_VOICE_DISTRESS_URL=http://localhost:5002
GROQ_API_KEY=api_key