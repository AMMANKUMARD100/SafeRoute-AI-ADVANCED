# SafeRoute AI – Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit the real .env file!

# ==========================================
# Server / Backend
# ==========================================
PORT=5000
NODE_ENV=development

# MongoDB Atlas or local connection string
MONGODB_URI=mongodb://localhost:27017

# JWT Authentication
JWT_SECRET=JWT_SECRET_KEY
JWT_EXPIRE=30d

# ==========================================
# Maps & External APIs (replacing Google Maps)
# OpenRouteService (server-side routing) - required if you want server routing
ORS_API_KEY=ORS_API_KEY
# OpenWeatherMap (weather / heat index)
OPENWEATHER_API_KEY=OPENWEATHER_API_KEY
# Optional: Geoapify for server-side geocoding (client uses REACT_APP_GEOAPIFY_API_KEY)
GEOAPIFY_API_KEY=GEOAPIFY_API_KEY

# ==========================================
# Twilio (SMS Notifications)
# ==========================================
TWILIO_SID=TWILIO_SID
TWILIO_AUTH_TOKEN=TWILIO_AUTH_TOKEN
TWILIO_PHONE=TWILIO_PHONE_NUMBER
# Optional override recipient for SOS alerts (your real phone number)
# SOS_RECIPIENT_PHONE=+919445644692

# ==========================================
# SendGrid (Email Notifications)
# ==========================================
SENDGRID_API_KEY=SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=SENDGRID_FROM_EMAIL

# ==========================================
# AI Microservices (Python/Flask)
# ==========================================
AI_ROUTE_SCORER_URL=http://localhost:5001
AI_VOICE_DISTRESS_URL=http://localhost:5002 
# ==========================================
# AI Microservices (Python/Flask)
# ==========================================
AI_ROUTE_SCORER_URL=http://localhost:5001
AI_VOICE_DISTRESS_URL=http://localhost:5002
GROQ_API_KEY=GROQ_API_KEY