# JWT Authentication
JWT_SECRET=a0d5d7c27f47665c5ca070e8018a9fe25395ba72a3f207a27578eb276b2ad373a32677096641b8c6248692f500b5a9280845db97bd7c7d9b8bbfbf10af7bbd4c
