EMAILJS_SERVICE_ID=service_h948jkz
EMAILJS_TEMPLATE_ID=template_ipjnaqn
+ALERT_EMAIL_TO=amman100d@gmail.com
# Optional override email address for alerts (overrides template `to_email`)
EMAILJS_TO_EMAIL=amman100d@gmail.com
